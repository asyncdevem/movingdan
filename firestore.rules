rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isManager() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }
    
    // Users collection
    match /users/{userId} {
      // Allow unauthenticated reads for employee login verification via API routes
      // Managers (authenticated) can read all users
      // Server-side API routes need this for employee authentication
      allow read: if true;
      
      // Users can only write their own profile
      // Managers can write any profile (for onboarding)
      allow write: if isOwner(userId) || isManager();
    }
    
    // Policies collection
    match /policies/{policyId} {
      // Allow unauthenticated reads for employee access via API routes
      allow read: if true;
      
      // Only managers can create/update/delete policies
      allow write: if isManager();
    }
    
    // Signatures collection
    match /signatures/{signatureId} {
      // Allow unauthenticated reads for employee access via API routes
      allow read: if true;
      
      // Allow unauthenticated creates for employee policy signing via API routes
      allow create: if true;
      allow update, delete: if false;
    }
    
    // Warnings collection
    match /warnings/{warningId} {
      // Allow unauthenticated reads for employee access via API routes
      allow read: if true;
      
      // Only managers can create/update warnings
      allow create, update: if isManager();
      
      // Warnings cannot be deleted (permanent record)
      allow delete: if false;
    }
    
    // Email queue collection (internal only)
    match /emailQueue/{queueId} {
      // Only Cloud Functions can access email queue via Admin SDK
      // Regular users and even managers cannot access this
      allow read, write: if false;
    }
    
    // Catch-all rule (deny everything else)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
